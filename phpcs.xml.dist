<?xml version="1.0"?>
<ruleset name="Terminal Image Coding Standards">
    <description>PSR-12 coding standards for Terminal Image</description>

    <!-- Scan these files -->
    <file>src</file>

    <!-- Ignore 3P directories -->
    <exclude-pattern>*/opensrc/*</exclude-pattern>
    <exclude-pattern>*/vendor/*</exclude-pattern>

    <!-- Show progress, show sniff codes in all reports -->
    <arg value="sp"/>

    <!-- Set minimum supported PHP version -->
    <config name="testVersion" value="7.4-"/>

    <!-- Enable colors in output -->
    <arg name="colors"/>

    <!-- Use PSR-12 standard -->
    <rule ref="PSR12"/>

    <!-- Check PHP 7.4 compatibility -->
    <rule ref="PHPCompatibility">
        <!--
            imagedestroy() is deprecated since PHP 8.0 but required to free GD
            resources on PHP 7.4 where GD images are not GdImage objects yet.
        -->
        <exclude name="PHPCompatibility.FunctionUse.RemovedFunctions.imagedestroyDeprecated"/>
    </rule>

    <!-- Enforce namespace best practices -->
    <rule ref="SlevomatCodingStandard.Namespaces.DisallowGroupUse"/>
    <rule ref="SlevomatCodingStandard.Namespaces.UseDoesNotStartWithBackslash"/>
    <rule ref="SlevomatCodingStandard.Namespaces.AlphabeticallySortedUses"/>
    <rule ref="SlevomatCodingStandard.Namespaces.UseFromSameNamespace"/>
    <rule ref="SlevomatCodingStandard.Namespaces.UnusedUses">
        <properties>
            <property name="searchAnnotations" value="true"/>
        </properties>
    </rule>
</ruleset>
